{
	"name": "equipe",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"infra:start": "docker compose -f docker-compose.infra.yml up -d --wait && npm run db:push",
		"infra:stop": "docker compose -f docker-compose.infra.yml down",
		"infra:rebuild": "docker compose -f docker-compose.infra.yml build && docker compose -f docker-compose.infra.yml up -d --wait && npm run db:push",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.15.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25",
		"better-auth": "~1.5.5",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"postgres": "^3.4.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.53.12",
		"svelte-check": "^4.4.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^8.0.0",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"carbon-components-svelte": "^0.103.0",
		"carbon-icons-svelte": "^13.9.0",
		"livekit-client": "^2.17.3",
		"livekit-server-sdk": "^2.15.0"
	},
	"overrides": {
		"@better-auth/core": "1.5.5"
	}
}
